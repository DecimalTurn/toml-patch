{
  "name": "@decimalturn/toml-patch",
  "version": "0.3.3",
  "contributors": [
    "Tim Hall <tim.hall.engr@gmail.com>",
    "Martin Leduc <31558169+DecimalTurn@users.noreply.github.com>"
  ],
  "license": "MIT",
  "description": "Patch, parse, and stringify TOML",
  "homepage": "https://github.com/DecimalTurn/toml-patch",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "toml",
    "patch",
    "parse",
    "stringify",
    "parser",
    "encoder",
    "decoder"
  ],
  "main": "dist/toml-patch.cjs.min.js",
  "module": "dist/toml-patch.es.js",
  "browser": "dist/toml-patch.umd.min.js",
  "types": "dist/toml-patch.d.ts",
  "scripts": {
    "test": "jest",
    "typecheck": "tsc",
    "specs": "jest --config specs.config.js",
    "benchmark": "node benchmark/index.js",
    "build": "rimraf dist && rollup -c",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/dedent": "^0.7.2",
    "@types/glob": "^8.0.0",
    "@types/jest": "^29.0.0",
    "@types/js-yaml": "^3",
    "benchmark": "^2",
    "dedent": "^1.5.3",
    "glob": "^11.0.0",
    "jest": "^29.7.0",
    "js-yaml": "^3",
    "mri": "^1",
    "npm-run-all2": "^8.0.0",
    "rimraf": "^6.0.0",
    "rollup": "^4.38.0",
    "rollup-plugin-dts": "^6.2.1",
    "rollup-plugin-filesize": "^10",
    "ts-jest": "^29",
    "tslib": "^1",
    "typescript": "4.9"
  },
  "jest": {
    "testEnvironment": "node",
    "preset": "ts-jest",
    "testRegex": "/__tests__/.*\\.[jt]sx?$",
    "snapshotFormat": {
      "escapeString": true,
      "printBasicPrototype": true
    }
  },
  "prettier": {
    "singleQuote": true,
    "printWidth": 100
  },
  "files": [
    "dist/"
  ]
}
