{
  "compilerOptions": {
    "strict": true,
    "target": "es2015",
    "moduleResolution": "bundler",
    "types": ["jest", "node"],
    "lib": ["es2019"],
    "esModuleInterop": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["*.ts", "src/**/*"],
  "exclude": ["node_modules"]
}